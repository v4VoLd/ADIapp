<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 x:Class="ADIapp.Views.TopUserPanelView">

	<Grid>
		<!-- MAIN ROW -->
		<StackPanel Orientation="Horizontal"
					HorizontalAlignment="Right"
					VerticalAlignment="Top"
					Spacing="12">

			<!-- 🔔 BELL -->
			<Panel>
				<Border Width="44"
						Height="44"
						CornerRadius="12"
						Background="#2A2A2A"
						PointerPressed="Bell_Click">
					<TextBlock Text="🔔"
							   FontSize="18"
							   HorizontalAlignment="Center"
							   VerticalAlignment="Center"/>
				</Border>
				<!-- Badge Red Dot -->
				<Border x:Name="NotificationBadge"
						Width="10"
						Height="10"
						CornerRadius="5"
						Background="#FF4D4D"
						HorizontalAlignment="Right"
						VerticalAlignment="Top"
						Margin="0,2,2,0"
						IsVisible="False"
						IsHitTestVisible="False"/>
			</Panel>

			<!-- USER CARD -->
			<Border CornerRadius="14"
					Background="#2A2A2A"
					Padding="12"
					PointerPressed="User_Click">

				<Grid ColumnDefinitions="Auto,Auto">
					<!-- Avatar -->
					<Border Width="40"
							Height="40"
							CornerRadius="17"
							Background="#4A4A4A"
							Margin="0,0,10,0"
							ClipToBounds="True">

						<Image Source="avares://ADIapp/Assets/avatar.png"
							   Stretch="UniformToFill"/>
					</Border>


					<!-- Text -->
					<StackPanel Grid.Column="1">
						<TextBlock Text="Hello,"
								   FontSize="11"
								   Foreground="#CFCFCF"/>
						<TextBlock x:Name="UserNameBlock"
								   Text="John Doe"
								   FontSize="13"
								   FontWeight="Bold"
								   Foreground="White"/>
						<Border Background="#1F1F1F"
								CornerRadius="8"
								Padding="8,3"
								Margin="0,4,0,0">
							<TextBlock x:Name="UserTokenBlock"
									   Text="Token: 8"
									   FontSize="11"
									   Foreground="White"/>
						</Border>
					</StackPanel>
				</Grid>
			</Border>
		</StackPanel>

		<!-- NOTIFICATION MENU -->
		<Border x:Name="NotificationMenu"
				IsVisible="False"
				Margin="0,60,110,0"
				Width="320"
				HorizontalAlignment="Right"
				VerticalAlignment="Top"
				CornerRadius="16"
				Background="#1E1E1E"
				Padding="16"
				ZIndex="10">

			<StackPanel Spacing="12">
				<Grid ColumnDefinitions="*,Auto">
					<TextBlock Text="Notifications"
							   FontWeight="Bold"
							   FontSize="16"
							   Foreground="White"
							   VerticalAlignment="Center"/>
					<Button Grid.Column="1"
							Content="Clear All"
							FontSize="11"
							FontWeight="SemiBold"
							Background="Transparent"
							Foreground="#CFCFCF"
							Padding="6,4"
							BorderThickness="0"
							Click="ClearNotifications_Click"/>
				</Grid>

				<Separator Height="1" Background="#2A2A2A"/>

				<ScrollViewer MaxHeight="300">
					<StackPanel x:Name="NotificationsList" Spacing="8">
						<!-- Notifications will be added dynamically here -->
					</StackPanel>
				</ScrollViewer>
			</StackPanel>
		</Border>

		<!-- EXPANDED MENU -->
		<Border x:Name="Menu"
				IsVisible="False"
				Margin="0,60,0,0"
				HorizontalAlignment="Right"
				CornerRadius="16"
				Background="#1E1E1E"
				Padding="20">

			<StackPanel Spacing="18">

				<Button Content="Account"
						FontSize="16"
						Foreground="White"
						Background="Transparent"
						BorderThickness="0"
						HorizontalContentAlignment="Left"
						Click="Account_Click"/>

				<Button Content="Token"
						FontSize="16"
						Foreground="White"
						Background="Transparent"
						BorderThickness="0"
						HorizontalContentAlignment="Left"
						Click="Token_Click"/>

				<Button Content="Logout"
						FontSize="16"
						Foreground="White"
						Background="Transparent"
						BorderThickness="0"
						HorizontalContentAlignment="Left"
						Click="Logout_Click"/>

			</StackPanel>
		</Border>


	</Grid>
</UserControl>
