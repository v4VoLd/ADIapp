<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="ADIapp.Views.TicketView">

    <StackPanel HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="24">

        <TextBlock Text="Tickets"
                   FontSize="36"
                   FontWeight="Bold"
                   Foreground="White"
                   HorizontalAlignment="Center"/>

        <StackPanel Spacing="18"
                    HorizontalAlignment="Center">

            <StackPanel>
                <TextBlock Text="New tickets"
                           FontSize="20"
                           Foreground="White"
                           HorizontalAlignment="Center"/>

                <Button Content="Request new tickets"
                        FontSize="18"
                        FontWeight="Bold"
                        Background="White"
                        Foreground="Black"
                        Margin="0,30,0,0"
                        HorizontalAlignment="Center"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        Width="250"
                        Height="50"/>
            </StackPanel>

        </StackPanel>
    </StackPanel>

</UserControl>
