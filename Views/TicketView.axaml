<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="ADIapp.Views.TicketView">

    <Grid RowDefinitions="Auto,*,Auto" Margin="24">
        <!-- Header -->
        <StackPanel Grid.Row="0" Spacing="6" Margin="0,0,0,16">
            <TextBlock Text="Support Tickets &amp; Messages"
                       FontSize="26"
                       FontWeight="Bold"
                       Foreground="White"/>
            <TextBlock Text="Communicate directly with technical support regarding ECU additions and orders."
                       FontSize="13"
                       Foreground="#AAAAAA"/>
        </StackPanel>

        <!-- Messages Container -->
        <Border Grid.Row="1"
                Background="#181818"
                BorderBrush="#2D2D2D"
                BorderThickness="1"
                CornerRadius="12"
                Padding="16">
            <ScrollViewer x:Name="MessagesScrollViewer" VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="MessagesPanel" Spacing="12"/>
            </ScrollViewer>
        </Border>

        <!-- Input Panel -->
        <Grid Grid.Row="2" ColumnDefinitions="*,Auto" Margin="0,16,0,0">
            <TextBox x:Name="MessageInput"
                     Grid.Column="0"
                     Watermark="Type your support message..."
                     Height="44"
                     CornerRadius="8"
                     Background="#252525"
                     Foreground="White"
                     BorderBrush="#3D3D3D"
                     Padding="12,10"
                     Margin="0,0,12,0"/>
            <Button x:Name="SendButton"
                    Grid.Column="1"
                    Content="Send Message"
                    Height="44"
                    Padding="20,0"
                    Background="White"
                    Foreground="Black"
                    FontWeight="Bold"
                    CornerRadius="8"
                    Click="SendButton_Click"/>
        </Grid>
    </Grid>

</UserControl>
