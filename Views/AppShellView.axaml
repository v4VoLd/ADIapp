<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="using:ADIapp.Views"
             x:Class="ADIapp.Views.AppShellView">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="20*"/>
            <ColumnDefinition Width="80*"/>
        </Grid.ColumnDefinitions>

        <!-- ===================== SIDEBAR ===================== -->
        <views:SidebarView Grid.Column="0"/>

        <!-- ===================== MAIN ===================== -->
        <Grid Grid.Column="1">

            <!-- Background image -->
            <Image Source="avares://ADIapp/Assets/main_background.png"
                   Stretch="UniformToFill"/>

            <!-- TOP RIGHT USER SECTION (overlay) -->
            <views:TopUserPanelView
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,18,18,0"/>

            <!-- PAGE CONTENT SLOT -->
            <ContentControl x:Name="PageContent"
                            HorizontalContentAlignment="Stretch"
                            VerticalContentAlignment="Stretch"/>

        </Grid>
    </Grid>

</UserControl>
