<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 x:Class="ADIapp.Views.InfoView"
			 xmlns:views="using:ADIapp.Views"
			 >

	<Grid >
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="20*"/>
			<ColumnDefinition Width="80*"/>
		</Grid.ColumnDefinitions>

		<!-- ===================== SIDEBAR ===================== -->
		<views:SidebarView Grid.Column="0"/>



		<!-- ===================== MAIN ===================== -->
		<Grid Grid.Column="1">

			<!-- Background -->
			<Image Source="avares://ADIapp/Assets/main_background.png"
				   Stretch="UniformToFill"/>

			<!-- TOP RIGHT USER SECTION (overlay) -->
			<views:TopUserPanelView
			HorizontalAlignment="Right"
			VerticalAlignment="Top"
			Margin="0,18,18,0"/>

			<!-- ================= CONTENT ================= -->
			<StackPanel HorizontalAlignment="Center"
						VerticalAlignment="Center"
						Spacing="32">

				<TextBlock Text="About us"
						   FontSize="36"
						   FontWeight="Bold"
						   Foreground="White"
						   HorizontalAlignment="Center"/>

				<StackPanel Spacing="18"
							HorizontalAlignment="Center">

					<StackPanel>
						<TextBlock Text="Our Website"
								   FontSize="20"
								   FontWeight="Bold"
								   Foreground="White"
								   HorizontalAlignment="Center"/>
						<TextBlock Text="adi-performance.com"
								   FontSize="16"
								   Foreground="#CFCFCF"
								   HorizontalAlignment="Center"/>
					</StackPanel>

					<StackPanel>
						<TextBlock Text="Update"
								   FontSize="20"
								   FontWeight="Bold"
								   Foreground="White"
								   HorizontalAlignment="Center"/>
						<TextBlock Text="adi-performance.com"
								   FontSize="16"
								   Foreground="#CFCFCF"
								   HorizontalAlignment="Center"/>
					</StackPanel>

					<StackPanel>
						<TextBlock Text="News"
								   FontSize="20"
								   FontWeight="Bold"
								   Foreground="White"
								   HorizontalAlignment="Center"/>
						<TextBlock Text="adi-performance.com"
								   FontSize="16"
								   Foreground="#CFCFCF"
								   HorizontalAlignment="Center"/>
					</StackPanel>

					<StackPanel>
						<TextBlock Text="Phone number"
								   FontSize="20"
								   FontWeight="Bold"
								   Foreground="White"
								   HorizontalAlignment="Center"/>
						<TextBlock Text="05515454564"
								   FontSize="16"
								   Foreground="#CFCFCF"
								   HorizontalAlignment="Center"/>
					</StackPanel>

				</StackPanel>
			</StackPanel>

		</Grid>
	</Grid>
</UserControl>

