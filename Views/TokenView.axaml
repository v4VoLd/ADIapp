<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="ADIapp.Views.TokenView">

    <StackPanel HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Width="500"
                Spacing="28">

        <!-- TITLE -->
        <TextBlock Text="Token"
                   FontSize="36"
                   FontWeight="Bold"
                   Foreground="White"
                   HorizontalAlignment="Center"/>

        <!-- TOKEN DISPLAY -->
        <StackPanel Spacing="10">
            <Border Background="#1F1F1F"
                    CornerRadius="10"
                    Padding="14">
                <TextBlock x:Name="TokenText"
                           Text="8 Token"
                           FontSize="16"
                           FontWeight="Bold"
                           Foreground="White"/>
            </Border>
        </StackPanel>

    </StackPanel>

</UserControl>
