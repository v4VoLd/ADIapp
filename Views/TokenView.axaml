<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:views="using:ADIapp.Views"
			 x:Class="ADIapp.Views.TokenView">

	<Grid>
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="20*"/>
			<ColumnDefinition Width="80*"/>
		</Grid.ColumnDefinitions>

		<!-- SIDEBAR -->
		<views:SidebarView Grid.Column="0"/>

		<!-- MAIN -->
		<Grid Grid.Column="1">

			<!-- BACKGROUND -->
			<Image Source="avares://ADIapp/Assets/main_background.png"
				   Stretch="UniformToFill"/>

			<!-- TOP USER PANEL -->
			<views:TopUserPanelView
			HorizontalAlignment="Right"
			VerticalAlignment="Top"
			Margin="0,18,18,0"/>

			<!-- CONTENT -->
			<StackPanel HorizontalAlignment="Center"
						VerticalAlignment="Center"
						Width="500"
						Spacing="28">

				<!-- TITLE -->
				<TextBlock Text="Token"
						   FontSize="36"
						   FontWeight="Bold"
						   Foreground="White"
						   HorizontalAlignment="Center"/>

				<!-- LANGUAGE -->
				<StackPanel Spacing="10">


					<Border Background="#1F1F1F"
							CornerRadius="10"
							Padding="14">
											<TextBlock x:Name="TokenText"
							   Text="8 Token"
							   FontSize="16"
							   FontWeight="Bold"
							   Foreground="White"/>
					</Border>
				</StackPanel>

			</StackPanel>

		</Grid>
	</Grid>
</UserControl>

