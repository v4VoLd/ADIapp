<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="ADIapp.Views.TuneView">

    <!-- ================= TOGGLE STYLES ================= -->
    <UserControl.Styles>

        <!-- Toggle OFF -->
        <Style Selector="ToggleSwitch /template/ Border#PART_Track">
            <Setter Property="Background" Value="#2A2A2A"/>
            <Setter Property="CornerRadius" Value="20"/>
        </Style>

        <!-- Toggle ON -->
        <Style Selector="ToggleSwitch:checked /template/ Border#PART_Track">
            <Setter Property="Background" Value="#4DFF8A"/>
        </Style>

        <!-- Toggle thumb -->
        <Style Selector="ToggleSwitch /template/ Border#PART_Thumb">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="20"/>
        </Style>

    </UserControl.Styles>

    <Grid RowDefinitions="Auto,*" ColumnDefinitions="280,*">

        <!-- TITLE -->
        <StackPanel Grid.Row="0"
                    Grid.ColumnSpan="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Margin="80,20,0,0"
                    Spacing="12">

            <Image Source="avares://ADIapp/Assets/carLogo_icon.png"
                   Width="36"
                   Height="36"/>

            <TextBlock Text="BMW G20 320i"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="White"
                       VerticalAlignment="Center"/>
        </StackPanel>

        <!-- SIDEBAR TASKS LIST -->
        <Border Grid.Row="1"
                Grid.Column="0"
                Margin="80,20,10,80"
                Padding="20"
                CornerRadius="22"
                Background="#141414"
                Opacity="0.92"
                VerticalAlignment="Stretch">
            <Grid RowDefinitions="Auto,Auto,*">
                <TextBlock Grid.Row="0"
                           Text="Active Tasks"
                           FontSize="18"
                           FontWeight="Bold"
                           Foreground="White"
                           Margin="0,0,0,15"/>
                <Button Grid.Row="1"
                        x:Name="NewFileButton"
                        Content="+ New Upload"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"
                        Background="#252525"
                        Foreground="White"
                        FontWeight="SemiBold"
                        Margin="0,0,0,15"
                        Padding="0,8"
                        Click="NewFileButton_Click"/>
                <ScrollViewer Grid.Row="2">
                    <StackPanel x:Name="ActiveFilesList" Spacing="8">
                        <TextBlock Text="No active tasks" 
                                   Foreground="Gray" 
                                   FontSize="12" 
                                   HorizontalAlignment="Center" 
                                   Margin="0,20,0,0"/>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- MAIN CARD -->
        <Border Grid.Row="1"
                Grid.Column="1"
                Margin="10,20,80,80"
                Padding="40"
                CornerRadius="22"
                Background="#1C1C1C"
                Opacity="0.92"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch">

            <Grid RowDefinitions="*,Auto,Auto"
                  ColumnDefinitions="*,*">

                <!-- SERVICES CONTAINER (Hidden by default, shown after ECU identification) -->
                <ScrollViewer x:Name="ServicesContainer"
                              Grid.Row="0"
                              Grid.ColumnSpan="2"
                              IsVisible="False"
                              VerticalScrollBarVisibility="Auto">
                    <WrapPanel x:Name="DynamicServicesPanel" 
                               Orientation="Horizontal" 
                               Margin="0,0,0,10"/>
                </ScrollViewer>

                <!-- ECU INFO CARD -->
                <Border Grid.Row="1"
                        Grid.ColumnSpan="2"
                        Background="#181818"
                        BorderBrush="#2D2D2D"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="16,12"
                        Margin="0,20,0,0"
                        HorizontalAlignment="Stretch">
                    <Grid ColumnDefinitions="*,Auto">
                        <!-- Details -->
                        <StackPanel Orientation="Horizontal" Spacing="24" VerticalAlignment="Center">
                            <StackPanel>
                                <TextBlock Text="ECU BRAND" FontSize="9" Foreground="#888888" FontWeight="Bold"/>
                                <TextBlock x:Name="EcuBrandText" Text="Not Loaded" FontSize="13" Foreground="White" FontWeight="SemiBold" Margin="0,2,0,0"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="ECU MODEL" FontSize="9" Foreground="#888888" FontWeight="Bold"/>
                                <TextBlock x:Name="EcuModelText" Text="Not Loaded" FontSize="13" Foreground="White" FontWeight="SemiBold" Margin="0,2,0,0"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="HARDWARE" FontSize="9" Foreground="#888888" FontWeight="Bold"/>
                                <TextBlock x:Name="EcuHardwareText" Text="Not Loaded" FontSize="13" Foreground="White" FontWeight="SemiBold" Margin="0,2,0,0"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="SOFTWARE" FontSize="9" Foreground="#888888" FontWeight="Bold"/>
                                <TextBlock x:Name="EcuSoftwareText" Text="Not Loaded" FontSize="13" Foreground="White" FontWeight="SemiBold" Margin="0,2,0,0"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Status -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <Border x:Name="StatusDot" Width="8" Height="8" CornerRadius="4" Background="Gray" VerticalAlignment="Center"/>
                            <TextBlock x:Name="StatusText" Text="Ready" FontSize="12" Foreground="#AAAAAA" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- BUTTONS -->
                <StackPanel Grid.Row="2"
                            Grid.ColumnSpan="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="0,30,0,0"
                            Spacing="18">

                    <Button Width="160"
                            Height="44"
                            Background="#2B2B2B"
                            Foreground="White"
                            Content="Original file"
                            Click="OriginalFile_Click"/>

                    <Button Width="160"
                            Height="44"
                            Background="White"
                            Foreground="Black"
                            FontWeight="Bold"
                            Content="Save"
                            Click="Save_Click"/>

                    <Button Width="160"
                            Height="44"
                            Background="#2B2B2B"
                            Foreground="White"
                            Content="DTC Off"/>

                </StackPanel>

            </Grid>
        </Border>

    </Grid>

</UserControl>
