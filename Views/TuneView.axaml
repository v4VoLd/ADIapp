<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="using:ADIapp.Views"
             x:Class="ADIapp.Views.TuneView">

    <!-- ================= TOGGLE STYLES ================= -->
    <UserControl.Styles>

        <!-- Toggle OFF -->
        <Style Selector="ToggleSwitch /template/ Border#PART_Track">
            <Setter Property="Background" Value="#2A2A2A"/>
            <Setter Property="CornerRadius" Value="20"/>
        </Style>

        <!-- Toggle ON -->
        <Style Selector="ToggleSwitch:checked /template/ Border#PART_Track">
            <Setter Property="Background" Value="#4DFF8A"/>
        </Style>

        <!-- Toggle thumb -->
        <Style Selector="ToggleSwitch /template/ Border#PART_Thumb">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="20"/>
        </Style>

    </UserControl.Styles>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="20*"/>
            <ColumnDefinition Width="80*"/>
        </Grid.ColumnDefinitions>

        <!-- ================= SIDEBAR ================= -->
        <views:SidebarView Grid.Column="0"/>

        <!-- ================= MAIN AREA ================= -->
        <Grid Grid.Column="1"
              RowDefinitions="Auto,*">

            <!-- BACKGROUND -->
            <Image Grid.RowSpan="2"
                   Source="avares://ADIapp/Assets/main_background.png"
                   Stretch="UniformToFill"/>

            <!-- TOP BAR -->
            <views:TopUserPanelView
                Grid.Row="0"
                HorizontalAlignment="Right"
                Margin="0,18,18,12"/>

            <!-- CONTENT -->
            <Grid Grid.Row="1">

                <!-- TITLE -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            Margin="80,20,0,0"
                            Spacing="12">

                    <Image Source="avares://ADIapp/Assets/carLogo_icon.png"
                           Width="36"
                           Height="36"/>

                    <TextBlock Text="BMW G20 320i"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="White"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- MAIN CARD -->
                <Border Margin="80,80,80,80"
                        Padding="40"
                        CornerRadius="22"
                        Background="#1C1C1C"
                        Opacity="0.92"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch">

                    <Grid RowDefinitions="*,Auto"
                          ColumnDefinitions="*,*">

                        <!-- LEFT COLUMN -->
                        <StackPanel Spacing="12">

                            <TextBlock Text="Stage 1" Foreground="White"/>
                            <ToggleSwitch/>

                            <TextBlock Text="Stage 2" Foreground="White"/>
                            <ToggleSwitch/>

                            <TextBlock Text="Stage 3" Foreground="White"/>
                            <ToggleSwitch/>

                            <TextBlock Text="Stage 4" Foreground="White"/>
                            <ToggleSwitch/>

                            <TextBlock Text="Stage 5" Foreground="White"/>
                            <ToggleSwitch/>

                            <TextBlock Text="Stock" Foreground="White"/>
                            <ProgressBar Height="8"
                                         Value="60"
                                         Background="#333"
                                         Foreground="#4DFF8A"/>

                            <TextBlock Text="147 hp"
                                       FontSize="12"
                                       Foreground="#AAAAAA"/>
                        </StackPanel>

                        <!-- RIGHT COLUMN -->
                        <StackPanel Grid.Column="1" Spacing="12">

                            <TextBlock Text="Pop &amp; Bang" Foreground="White"/>
                            <ToggleSwitch/>

                            <TextBlock Text="EGR Off" Foreground="White"/>
                            <ToggleSwitch/>

                            <TextBlock Text="DPF Off" Foreground="White"/>
                            <ToggleSwitch/>

                            <TextBlock Text="Cold Start Off" Foreground="White"/>
                            <ToggleSwitch/>

                            <TextBlock Text="Rev Limiter" Foreground="White"/>
                            <ToggleSwitch/>

                            <TextBlock Text="Stock" Foreground="White"/>
                            <ProgressBar Height="8"
                                         Value="60"
                                         Background="#333"
                                         Foreground="#4DFF8A"/>

                            <TextBlock Text="147 hp"
                                       FontSize="12"
                                       Foreground="#AAAAAA"/>
                        </StackPanel>

                        <!-- BUTTONS -->
                        <StackPanel Grid.Row="1"
                                    Grid.ColumnSpan="2"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    Margin="0,30,0,0"
                                    Spacing="18">

                            <Button Width="160"
                                    Height="44"
                                    Background="#2B2B2B"
                                    Foreground="White"
                                    Content="Original file"/>

                            <Button Width="160"
                                    Height="44"
                                    Background="White"
                                    Foreground="Black"
                                    FontWeight="Bold"
                                    Content="Save"
                                    Click="Save_Click"/>

                            <Button Width="160"
                                    Height="44"
                                    Background="#2B2B2B"
                                    Foreground="White"
                                    Content="DTC Off"/>

                        </StackPanel>

                    </Grid>
                </Border>

            </Grid>
        </Grid>
    </Grid>
</UserControl>




